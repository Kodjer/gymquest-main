// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Модель пользователя (для NextAuth)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  player        Player?
  quests        Quest[]
  
  @@map("users")
}

// Аккаунты (для NextAuth)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Сессии (для NextAuth)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Токены верификации email (для NextAuth)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Профиль игрока
model Player {
  id                  String   @id @default(cuid())
  userId              String   @unique
  level               Int      @default(1)
  xp                  Int      @default(0)
  onboardingCompleted Boolean  @default(false)
  completedQuests     Int      @default(0) // Количество завершенных квестов
  lastQuestGenerated  DateTime? // Дата последней генерации квестов
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  onboardingData      OnboardingData?
  
  @@map("players")
}

// Квесты (задачи)
model Quest {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?  @db.Text
  instructions String? @db.Text
  tip         String?  @db.Text
  xpReward    Int
  difficulty  String   // easy, medium, hard
  category    String   // strength, cardio, flexibility, wellness
  status      String   @default("pending") // pending, done
  isGenerated Boolean  @default(true) // Автоматически сгенерирован или создан пользователем
  visualDemo  String?  @db.Text // JSON: {type, url, thumbnail}
  stepByStep  String?  @db.Text // JSON массив шагов
  assignedAt  DateTime @default(now())
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([userId, status])
  @@map("quests")
}

// Данные опросника
model OnboardingData {
  id                String   @id @default(cuid())
  playerId          String   @unique
  howDidYouHear     String
  age               Int
  weight            Float
  height            Float
  fitnessExperience String   // начинающий, средний, продвинутый
  availableTime     String   // 15-30 минут, 30-60 минут, и т.д.
  workoutPreference String   @db.Text // JSON массив предпочтений
  fitnessGoals      String   @db.Text // JSON массив целей
  injuries          String?  @db.Text
  dietPreference    String
  completedAt       DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  player            Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  
  @@map("onboarding_data")
}

// История XP (опционально для графиков)
model XpHistory {
  id        String   @id @default(cuid())
  userId    String
  xp        Int
  timestamp DateTime @default(now())
  
  @@index([userId])
  @@map("xp_history")
}
